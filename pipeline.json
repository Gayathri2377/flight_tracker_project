{
  "name": "Flight_tracking_pipeline",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "trigger": {
    "pause_status": "UNPAUSED",
    "periodic": {
      "interval": 1,
      "unit": "HOURS"
    }
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Bronze_Layer",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/flight_tracker_project/01_Bronze_ADSB",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Sliver",
      "depends_on": [
        {
          "task_key": "Bronze_Layer"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/silver",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Gold",
      "depends_on": [
        {
          "task_key": "Sliver"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Gold",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    }
  ],
  "git_source": {
    "git_url": "https://github.com/Gayathri2377/flight_tracker_project",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "queue": {
    "enabled": true
  },
  "performance_target": "PERFORMANCE_OPTIMIZED"
}
